---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { difyConfig } from "@/config/difyConfig";
import { i18n } from "@/i18n/translation";
import I18nKey from "@/i18n/i18nKey";

const title = i18n(I18nKey.askAI);
const description = i18n(I18nKey.askAIDescription);
---

<MainGridLayout
  title={title}
  description={description}
>
  <div class="ask-ai-page">
    <div class="ask-ai-header">
      <h1 class="ask-ai-title">🤖 {title}</h1>
      <p class="ask-ai-desc">{description}</p>
    </div>

    {
      difyConfig.enable && difyConfig.embedUrl ? (
        <div class="ask-ai-container">
          <iframe
            src={difyConfig.embedUrl}
            style={`height: ${difyConfig.height}; border: none; width: 100%;`}
            class="dify-iframe"
            title={title}
            allow="microphone"
          ></iframe>
        </div>
      ) : (
        <div class="ask-ai-placeholder">
          <div class="placeholder-icon">🧠</div>
          <h2>AI 问答功能尚未配置</h2>
          <p>
            请在 <code>src/config/difyConfig.ts</code> 中设置
            <code>enable: true</code> 并填入 Dify 应用的嵌入式 URL。
          </p>
          <div class="setup-steps">
            <h3>配置步骤：</h3>
            <ol>
              <li>注册 <a href="https://dify.ai" target="_blank" rel="noopener noreferrer">Dify Cloud</a> 账号</li>
              <li>创建知识库 → 导入博客文章</li>
              <li>创建聊天助手应用 → 配置 Prompt</li>
              <li>在应用「概览」→「嵌入」中获取 iframe URL</li>
              <li>将 URL 填入 <code>difyConfig.embedUrl</code></li>
            </ol>
          </div>
        </div>
      )
    }
  </div>
</MainGridLayout>

<style is:global>
  .ask-ai-page {
    max-width: var(--page-width, 100%);
    margin: 0 auto;
    padding: 24px 16px 48px;
  }

  .ask-ai-header {
    text-align: center;
    margin-bottom: 24px;
  }

  .ask-ai-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-color, #1f2937);
    margin-bottom: 8px;
  }

  .ask-ai-desc {
    font-size: 0.95rem;
    color: var(--text-secondary, #6b7280);
    max-width: 560px;
    margin: 0 auto;
  }

  .ask-ai-container {
    border-radius: var(--radius-large, 12px);
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
    background: var(--card-bg, #fff);
  }

  .dify-iframe {
    display: block;
    border-radius: var(--radius-large, 12px);
  }

  .ask-ai-placeholder {
    text-align: center;
    padding: 48px 24px;
    background: var(--card-bg, #fff);
    border-radius: var(--radius-large, 12px);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
  }

  .placeholder-icon {
    font-size: 3rem;
    margin-bottom: 16px;
  }

  .ask-ai-placeholder h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-color, #1f2937);
    margin-bottom: 8px;
  }

  .ask-ai-placeholder p {
    color: var(--text-secondary, #6b7280);
    margin-bottom: 24px;
  }

  .ask-ai-placeholder code {
    background: var(--inline-code-bg, rgba(0, 0, 0, 0.06));
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.875rem;
  }

  .setup-steps {
    text-align: left;
    max-width: 480px;
    margin: 0 auto;
    padding: 20px;
    background: var(--bg-secondary, rgba(0, 0, 0, 0.03));
    border-radius: 8px;
  }

  .setup-steps h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--text-color, #1f2937);
  }

  .setup-steps ol {
    padding-left: 20px;
    color: var(--text-secondary, #6b7280);
    font-size: 0.9rem;
    line-height: 2;
  }

  .setup-steps a {
    color: var(--primary, #10b981);
    text-decoration: underline;
  }

  :global(.dark) .ask-ai-placeholder {
    background: var(--card-bg, #1f2937);
  }

  :global(.dark) .setup-steps {
    background: rgba(255, 255, 255, 0.05);
  }
</style>