---
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { tagGroups } from "@/config/tagGroupConfig";
import { getTagList } from "@/utils/content-utils";
import { getTagUrl } from "@/utils/url-utils";

const allTags = await getTagList();
const tagCountMap = new Map(allTags.map((t) => [t.name, t.count]));

// 按分组整理标签，只显示有文章的分组
const groupedTags = tagGroups
	.map((group) => ({
		...group,
		activeTags: group.tags
			.filter((tag) => tagCountMap.has(tag) && (tagCountMap.get(tag) ?? 0) > 0)
			.map((tag) => ({
				name: tag,
				count: tagCountMap.get(tag) ?? 0,
			})),
	}))
	.filter((g) => g.activeTags.length > 0);

// 所有未归入分组的标签
const groupedTagNames = new Set(tagGroups.flatMap((g) => g.tags));
const ungroupedTags = allTags.filter((t) => !groupedTagNames.has(t.name));

// 计算颜色深度
const maxCount = Math.max(...allTags.map((t) => t.count), 1);
const minCount = Math.min(...allTags.map((t) => t.count), 1);
const getDepth = (count: number) => {
	if (maxCount === minCount) return 0.5;
	return (count - minCount) / (maxCount - minCount);
};

// Top 10
const topTags = [...allTags].sort((a, b) => b.count - a.count).slice(0, 10);
const topMaxCount = topTags.length > 0 ? topTags[0].count : 1;
---

<MainGridLayout title={i18n(I18nKey.tags)} description={i18n(I18nKey.allTags)}>
  <!-- 页面标题 -->
  <div class="card-base px-8 py-6 mb-4">
    <div class="text-2xl font-bold text-(--primary) mb-1">
      🗂️ {i18n(I18nKey.tags)}
    </div>
    <p class="text-30 text-sm">
      能力地图 · {allTags.length} 个标签 · {allTags.reduce((s, t) => s + t.count, 0)} 篇文章
    </p>
  </div>

  <!-- 能力地图：按分组展示 -->
  {
    groupedTags.length > 0 && (
      <div class="flex flex-col gap-4">
        {groupedTags.map((group) => (
          <div class="card-base z-10 px-6 py-5 relative w-full">
            <div class="flex items-center gap-2.5 mb-3">
              <div class="h-8 w-8 rounded-lg bg-(--primary)/10 text-(--primary) flex items-center justify-center shrink-0">
                <Icon is:inline name={group.icon} class="text-lg" />
              </div>
              <h2 class="text-base font-bold text-75">{group.name}</h2>
              <span class="text-xs text-30 ml-auto">{group.activeTags.length} 个标签</span>
            </div>
            <div class="flex flex-wrap gap-2">
              {group.activeTags.map((t) => (
                <a href={getTagUrl(t.name)}
                   class="tag-item group inline-flex items-center gap-1.5 rounded-lg
                          h-8 text-sm px-3 transition-all duration-200
                          hover:scale-105 hover:shadow-md"
                   style={`--tag-depth: ${getDepth(t.count)}`}
                >
                  <span class="font-medium">
                    <span class="opacity-50">#</span>{t.name}
                  </span>
                  <span class="tag-count-badge text-xs font-bold px-1.5 rounded-md
                               min-w-[1.5rem] text-center">
                    {t.count}
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    )
  }

  <!-- 未分组标签 -->
  {ungroupedTags.length > 0 && (
    <div class="card-base z-10 px-6 py-5 relative w-full mt-4">
      <div class="flex items-center gap-2.5 mb-3">
        <div class="h-8 w-8 rounded-lg bg-(--primary)/10 text-(--primary) flex items-center justify-center shrink-0">
          <Icon is:inline name="material-symbols:more-horiz" class="text-lg" />
        </div>
        <h2 class="text-base font-bold text-75">其他标签</h2>
      </div>
      <div class="flex flex-wrap gap-2">
        {ungroupedTags.map((t) => (
          <a href={getTagUrl(t.name)}
             class="tag-item group inline-flex items-center gap-1.5 rounded-lg
                    h-8 text-sm px-3 transition-all duration-200
                    hover:scale-105 hover:shadow-md"
             style={`--tag-depth: ${getDepth(t.count)}`}
          >
            <span class="font-medium">
              <span class="opacity-50">#</span>{t.name}
            </span>
            <span class="tag-count-badge text-xs font-bold px-1.5 rounded-md
                         min-w-[1.5rem] text-center">
              {t.count}
            </span>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- 空状态 -->
  {
    allTags.length === 0 && (
      <div class="card-base px-8 py-12 text-center">
        <Icon is:inline name="material-symbols:tag-off" class="text-5xl text-30 mx-auto mb-4" />
        <p class="text-30">{i18n(I18nKey.noData)}</p>
      </div>
    )
  }

  <!-- Top 10 标签排行 -->
  {topTags.length > 0 && (
    <div class="card-base px-8 py-6 mt-4">
      <h2 class="text-lg font-bold text-75 mb-4">🏆 Top 10 热门标签</h2>
      <div class="flex flex-col gap-3">
        {topTags.map((t, i) => (
          <a href={getTagUrl(t.name)}
             class="flex items-center gap-3 group hover:bg-(--btn-card-bg-hover) rounded-lg px-3 py-2 -mx-3 transition-colors"
          >
            <span class="text-sm font-bold text-(--primary) w-5 text-right shrink-0">
              {i + 1}
            </span>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-medium text-50 truncate group-hover:text-(--primary) transition-colors">
                  #{t.name.trim()}
                </span>
                <span class="text-xs text-(--primary) ml-2 shrink-0">
                  {t.count} {i18n(I18nKey.postsCount)}
                </span>
              </div>
              <div class="h-2 rounded-full bg-(--primary)/10 overflow-hidden">
                <div
                  class="h-full rounded-full bg-(--primary) transition-all duration-500"
                  style={`width: ${(t.count / topMaxCount) * 100}%`}
                />
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}
</MainGridLayout>
